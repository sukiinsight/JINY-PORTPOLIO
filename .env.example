TELEGRAM_BOT_TOKEN=
OPENAI_API_KEY=
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Optional. Comma-separated Telegram numeric user IDs allowed to use the bot.
# Leave blank to allow anyone who can reach the bot.
ALLOWED_TELEGRAM_USER_IDS=

# Optional. Defaults to gpt-5.5.
OPENAI_MODEL=gpt-5.5

# Optional. Use webhook in production. If omitted, the bot uses long polling.
# PUBLIC_WEBHOOK_URL=https://your-domain.example.com
# PORT=3000
